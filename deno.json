{
  "name": "muddbro-network",
  "version": "0.4.0",
  "description": "Muddbro Network — Telegram-native Web3 gaming ecosystem on TON",
  "tasks": {
    "dev": "deno run --allow-net --allow-env --allow-read src/main.ts",
    "test": "deno test",
    "check": "deno check",
    "deploy": "deno deploy",
    "lint": "deno lint"
  },
  "imports": {
    "@ton/ton": "npm:@ton/ton@15.0.0",
    "@ton/crypto": "npm:@ton/crypto@3.2.0"
  },
  "fmt": {
    "indentWidth": 2,
    "lineWidth": 100,
    "semiColons": true,
    "singleQuote": false
  },
  "lint": {
    "rules": {
      "exclude": ["no-explicit-any"]
    }
  }
}
