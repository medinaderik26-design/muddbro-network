# ─────────────────────────────────────────────
# Muddbro Network — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# NEVER commit the real .env file to git.

# ── Telegram Bot Tokens ──
# Ring Mine bot (@RingMine_Bot)
TELEGRAM_BOT_TOKEN_2_2=your_ringmine_bot_token_here

# Inner Earth bot (@InnerEarth_bot)
TELEGRAM_BOT_TOKEN_4=your_innerearth_bot_token_here

# ── TON Blockchain ──
# 24-word seed phrase for the G0_Architect wallet (holds 10M MUDD on testnet)
TON_SEED_PHRASE=word1 word2 word3 ... word24

# TON RPC endpoints (testnet defaults shown)
TON_TESTNET_ENDPOINT=https://testnet.toncenter.com/api/v2/jsonRPC
TONAPI_ENDPOINT=https://testnet.tonapi.io/v2

# G0 Architect wallet address (testnet, V5R1, networkGlobalId: -3)
G0_WALLET_ADDRESS=0QAG3lJZz24VOz6eicLTqP5M-YtfKJ96Naq3FPUz548Pcsw8

# ── AI / LLM ──
# Groq API key for Queen's Protocol quest generation
GROQ_API_KEY=your_groq_api_key_here

# ── Base44 ──
# The app ID for the Superagent hosting the backend functions
BASE44_APP_ID=6a4020251d35ee93ec909dfa

# Base44 function base URL (where deployed functions live)
BASE44_FUNCTION_BASE_URL=https://superagent-ec909dfa.base44.app/functions

# ── Game Economy ──
# MuddOre to MUDD conversion rate
MUDD_ORE_TO_MUDD_RATE=1000

# Minimum MuddOre withdrawal amount
MIN_WITHDRAWAL_MUDD_ORE=1000

# ── Optional: Toncenter API key (for higher rate limits) ──
# TONCENTER_API_KEY=your_toncenter_api_key_here
