# Ring Mine — Environment Variables
# Copy to .env and fill in

# Telegram Bot Token (Ring Mine — second bot)
TELEGRAM_BOT_TOKEN_2=your_ring_mine_token_here

# AI / Queen's Protocol
# Option A: OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Option B: Local LLM (LM Studio, Ollama, etc.)
# OPENAI_BASE_URL=http://localhost:1234/v1
# OPENAI_API_KEY=local
# OPENAI_MODEL=your-local-model-name
