#!/bin/bash
# Pre-commit hook: block commits containing secrets or large binaries
# Install: cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

set -e

# Check for hardcoded secrets
if git diff --cached --diff-filter=AM | grep -iE "BOT_TOKEN.*=.*[0-9]{8,}:[A-Za-z0-9_-]{30,}" 2>/dev/null; then
  echo "❌ BLOCKED: Hardcoded Telegram bot token detected. Use env vars instead."
  exit 1
fi

if git diff --cached --diff-filter=AM | grep -iE "SEED_PHRASE.*=.*[a-z]+\s+[a-z]+\s+[a-z]+" 2>/dev/null; then
  echo "❌ BLOCKED: Seed phrase detected in staged changes. Use env vars instead."
  exit 1
fi

if git diff --cached --diff-filter=AM | grep -iE "GROQ_API_KEY.*=.*gsk_[A-Za-z0-9]+" 2>/dev/null; then
  echo "❌ BLOCKED: Groq API key detected. Use env vars instead."
  exit 1
fi

# Check for large files (>1MB)
LARGE_FILES=$(git diff --cached --name-only --diff-filter=AM | while read f; do
  if [ -f "$f" ]; then
    SIZE=$(wc -c < "$f" 2>/dev/null || echo 0)
    if [ "$SIZE" -gt 1048576 ]; then
      echo "$f (${SIZE} bytes)"
    fi
  fi
done)

if [ -n "$LARGE_FILES" ]; then
  echo "❌ BLOCKED: Large files detected (>1MB). Use Git LFS or GitHub Releases:"
  echo "$LARGE_FILES"
  exit 1
fi

# Check for tar.gz/zip files
if git diff --cached --name-only --diff-filter=AM | grep -iE "\.(tar\.gz|zip|7z)$" 2>/dev/null; then
  echo "❌ BLOCKED: Binary archive detected. Use GitHub Releases instead."
  exit 1
fi

echo "✅ Pre-commit checks passed."
exit 0
